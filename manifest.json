{
  "manifest_version": 3,
  "name": "VTOP Auto Login",
  "version": "7.0.0",
  "description": "Fully automatic VTOP login. Solves CAPTCHA using the captop CRNN model (purpose-trained on real VTOP CAPTCHAs).",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://vtop.vitbhopal.ac.in/*",
    "https://captop-proxy.sykik.workers.dev/*",
    "https://captop.duckdns.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://vtop.vitbhopal.ac.in/vtop/login", "https://vtop.vitbhopal.ac.in/vtop/open/page", "https://vtop.vitbhopal.ac.in/vtop/login/error"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VTOP Auto Login",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
